OPENAI_API_KEY=
RESEND_API_KEY=
EMAIL_FROM="Digest <digest@example.com>"
EMAIL_TO="you@example.com"
TARGET_LANGUAGE=zh-CN
TIMEZONE=Asia/Shanghai
MAX_CANDIDATES=80
MAX_SELECTED=15
MIN_MATCH_SCORE=60
OPENAI_API_MODE=responses
OPENAI_MODEL=gpt-4.1-nano
SELECTION_MODEL=gpt-4.1-mini
SELECTION_REASONING_EFFORT=
SELECTION_REASONING_SUMMARY=
TRANSLATION_MODEL=gpt-4.1-nano
TRANSLATION_BATCH_SIZE=3
DRY_RUN=1
COMMIT_RUNTIME_STATE=0
